APP_DEBUG = true

DB_TYPE = mysql
DB_HOST = 127.0.0.1
DB_NAME = test
DB_USER = username
DB_PASS = password
DB_PORT = 3306
DB_CHARSET = utf8

DEFAULT_LANG = zh-cn

# 支付回调签名密钥（至少 32 位随机字符串）
PAY_NOTIFY_SECRET =

# 支付回调严格模式（1=开启，非支付宝必须携带 timestamp/nonce/sign）
PAY_NOTIFY_STRICT_MODE = 0

# 回调来源 IP 白名单（可选，逗号分隔，支持 CIDR；留空表示不限制）
# 示例：PAY_NOTIFY_TRUSTED_IPS=127.0.0.1,10.0.0.0/8
PAY_NOTIFY_TRUSTED_IPS =

# 回调时间戳允许窗口（秒），默认 1800（30 分钟）
PAY_NOTIFY_TIMESTAMP_WINDOW_SECONDS = 1800

# 回调重放保护缓存 TTL（秒），默认 86400（24 小时）
PAY_NOTIFY_REPLAY_TTL_SECONDS = 86400
