# 网站监控告警配置
# 复制此文件为 .env.monitor 并填入实际配置

# ================== MySQL 配置 ==================
MONITOR_MYSQL_HOST=127.0.0.1
MONITOR_MYSQL_PORT=3306
MONITOR_MYSQL_USER=root
MONITOR_MYSQL_PASSWORD=your_password
MONITOR_MAX_CONNECTIONS_THRESHOLD=100

# ================== Redis 配置 ==================
MONITOR_REDIS_HOST=127.0.0.1
MONITOR_REDIS_PORT=6379
MONITOR_REDIS_PASSWORD=your_redis_password
MONITOR_REDIS_MEMORY_WARNING=80.0

# ================== RabbitMQ 配置 ==================
MONITOR_RABBITMQ_HOST=127.0.0.1
MONITOR_RABBITMQ_PORT=15672
MONITOR_RABBITMQ_USER=guest
MONITOR_RABBITMQ_PASSWORD=guest
MONITOR_QUEUE_BACKLOG_THRESHOLD=1000

# ================== API 健康检查 ==================
MONITOR_API_BASE_URL=http://localhost:8082
MONITOR_API_TIMEOUT=5
MONITOR_API_RESPONSE_TIME_WARNING=3.0

# ================== Supervisor 配置 ==================
MONITOR_SUPERVISOR_HTTP_USER=admin
MONITOR_SUPERVISOR_HTTP_PASSWORD=admin_password

# ================== 日志监控 ==================
MONITOR_SUPERVISOR_LOG=/var/log/supervisor/supervisord.log
MONITOR_ERROR_COUNT_THRESHOLD=10

# ================== 通知配置 ==================
# 启用哪些通知方式（true/false）
MONITOR_USE_WECHAT=false
MONITOR_USE_DINGTALK=false
MONITOR_USE_EMAIL=false

# 企业微信机器人 Webhook（从企业微信后台获取）
MONITOR_WECHAT_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key

# 钉钉机器人 Webhook
MONITOR_DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your-token

# 邮件配置
MONITOR_EMAIL_SMTP=smtp.qq.com
MONITOR_EMAIL_PORT=465
MONITOR_EMAIL_USER=your_email@qq.com
MONITOR_EMAIL_PASS=your_email_password
MONITOR_EMAIL_TO=recipient1@qq.com,recipient2@qq.com

# ================== 其他配置 ==================
# 告警抑制时间（秒）- 相同告警在此时间内只发送一次
MONITOR_ALERT_SUPPRESS_SECONDS=300

# 告警状态文件路径
MONITOR_ALERT_STATE_FILE=/tmp/monitor_alert_state.json

# 监控日志路径
MONITOR_LOG_PATH=/var/log/site_monitor.log
